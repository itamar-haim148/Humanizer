# ==============================================================================
# Humanize AI Platform — environment variables
# Copy this file to `.env` and fill in for local dev; in Coolify set these via
# the project Environment Variables panel.
# ==============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=production

# --- Web (Next.js) -----------------------------------------------------------
# Public base URL used by the browser (must be reachable from the user's browser
# in production, e.g. https://your.coolify.domain ; in dev: http://localhost:8000)
NEXT_PUBLIC_API_BASE_URL=http://api:8000

# Server-side base URL used by Next.js inside the docker network
INTERNAL_API_BASE_URL=http://api:8000

# Host port to publish the web service on
WEB_PORT=3000

# --- API (FastAPI) -----------------------------------------------------------
# CORS allow-origin for the browser
WEB_ORIGIN=http://localhost:3000

# Maximum text length per request (characters)
MAX_TEXT_LENGTH=10000

# Sliding-window per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MIN=30

# Trust X-Forwarded-For (set true when behind Coolify's Caddy/Traefik proxy)
TRUST_PROXY=true

# Number of uvicorn workers
UVICORN_WORKERS=2

# --- SynthID (optional) ------------------------------------------------------
# Enable the SynthID watermark detector. Requires model download (first run).
ENABLE_SYNTHID=false

# Hugging Face model id used by the SynthID detector
SYNTHID_MODEL=google/gemma-2b

# --- LLM mode (Gemini Flash 3.5) --------------------------------------------
# All three required for /api/humanize/llm. Empty = endpoint returns 503.
# Set as Coolify secrets, NEVER commit real values.
GEMINI_API_KEY=
LLM_USER=
LLM_PASSWORD=

# Per-IP rate limit for the LLM endpoint (calls cost money)
LLM_RATE_LIMIT_PER_MIN=10
